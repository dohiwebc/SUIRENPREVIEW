---
import Layout from "../../../layouts/Layout.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { BLOG_CATEGORIES, absoluteUrl, withBase } from "../../../config";
import { getAllBlogPosts } from "../../../lib/microcms";
import BlogSort from "../../../components/BlogSort.astro";
import {
  getBlogCategories,
  getCategoryPath,
  getPostPublishedAtIso,
  postMatchesBlogCategory,
  sortBlogPostsByDate,
} from "../../../lib/utils";

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  const fromConfig = BLOG_CATEGORIES.filter((c) => c !== "すべて");
  const fromPosts = posts.flatMap((post) => getBlogCategories(post));
  const categories = [...new Set([...fromConfig, ...fromPosts])];

  return categories.map((category) => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const posts = await getAllBlogPosts();
const filtered = sortBlogPostsByDate(
  posts.filter((post) => postMatchesBlogCategory(post, category)),
  "newest"
);

const description = `${category} カテゴリの記事一覧。Suiren Notes。`;
---

<Layout
  title={`${category} | Blog | Suiren Notes`}
  description={description}
  canonical={absoluteUrl(getCategoryPath(category))}
  pageClass="page--blog"
>
  <div class="container page-hero">
    <span class="page-hero__label">記録</span>
    <h1 class="page-hero__title">{category}</h1>
    <p class="page-hero__lead">カテゴリ「{category}」の記事一覧</p>
  </div>

  <section class="section container" aria-label="記事一覧">
    <Breadcrumb
      items={[
        { label: "Home", href: withBase("/") },
        { label: "Blog", href: withBase("/blog/") },
        { label: category },
      ]}
    />
    <p class="section__more" style="margin-bottom: 1.5rem;">
      <a href={withBase("/blog/")} class="btn btn--secondary">← すべての記事</a>
    </p>
    <div class="blog-toolbar blog-toolbar--sort-only">
      <BlogSort />
    </div>
    <div id="blog-list">
      {
        filtered.length > 0 ? (
          <div class="card-grid card-grid--3">
            {filtered.map((post) => (
              <div data-published-at={getPostPublishedAtIso(post)}>
                <ArticleCard post={post} />
              </div>
            ))}
          </div>
        ) : (
          <p class="message message--empty">このカテゴリの記事はまだありません</p>
        )
      }
    </div>
  </section>
</Layout>
