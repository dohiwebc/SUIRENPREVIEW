---
interface Props {
  shareUrl: string;
  shareTitle: string;
  shareText: string;
}

const { shareUrl, shareTitle, shareText } = Astro.props;

const lineUrl = new URL("https://social-plugins.line.me/lineit/share");
lineUrl.searchParams.set("url", shareUrl);
lineUrl.searchParams.set("text", shareTitle);

const xUrl = new URL("https://twitter.com/intent/tweet");
xUrl.searchParams.set("text", shareTitle);
xUrl.searchParams.set("url", shareUrl);
---

<div class="article__share" aria-label="記事の共有">
  <p class="article__share-title">Share</p>
  <div class="article__share-buttons">
    <button
      type="button"
      class="article__share-btn article__share-btn--native"
      data-native-share
      hidden
      aria-label="共有メニューを開く"
    >
      <svg class="article__share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <circle cx="18" cy="5" r="3"></circle>
        <circle cx="6" cy="12" r="3"></circle>
        <circle cx="18" cy="19" r="3"></circle>
        <path d="m8.59 13.51 6.83 3.98"></path>
        <path d="m15.41 6.51-6.82 3.98"></path>
      </svg>
    </button>
    <a
      href={lineUrl.href}
      class="article__share-btn article__share-btn--line"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LINEで共有"
    >
      <svg class="article__share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          fill="currentColor"
          d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
        ></path>
      </svg>
    </a>
    <a
      href={xUrl.href}
      class="article__share-btn article__share-btn--x"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Xで共有"
    >
      <svg class="article__share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          fill="currentColor"
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.836-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        ></path>
      </svg>
    </a>
    <button
      type="button"
      class="article__share-btn article__share-btn--copy"
      data-copy-article-url
      aria-label="リンクをコピー"
    >
      <span class="article__share-btn__state" data-copy-icon>
        <svg class="article__share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.8"
            d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
          ></path>
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.8"
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
          ></path>
        </svg>
      </span>
      <span
        class="article__share-btn__state article__share-btn__state--check"
        data-check-icon
        hidden
      >
        <svg class="article__share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20 6 9 17l-5-5"
          ></path>
        </svg>
      </span>
    </button>
  </div>
  <span class="article__copy-status" data-copy-status aria-live="polite"></span>
  <input
    class="article__copy-url"
    type="text"
    value={shareUrl}
    data-copy-url
    readonly
    hidden
    aria-label="記事URL"
  />
</div>

<script define:vars={{ shareUrl, shareTitle, shareText }}>
  const shareData = { title: shareTitle, text: shareText, url: shareUrl };

  async function copyTextToClipboard(text) {
    const clipboard = window.navigator && window.navigator.clipboard;
    if (clipboard && window.isSecureContext) {
      await clipboard.writeText(text);
      return;
    }
    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.top = "-9999px";
    document.body.appendChild(textarea);
    textarea.select();
    const didCopy =
      typeof document.execCommand === "function" && document.execCommand("copy");
    textarea.remove();
    if (!didCopy) throw new Error("リンクをコピーできませんでした");
  }

  const nativeBtn = document.querySelector("[data-native-share]");
  if (nativeBtn && typeof navigator.share === "function") {
    nativeBtn.hidden = false;
    nativeBtn.addEventListener("click", async () => {
      try {
        await navigator.share(shareData);
      } catch (err) {
        if (err && err.name === "AbortError") return;
      }
    });
  }

  const headerShare = document.querySelector("[data-header-share]");
  const statusEl = document.querySelector("[data-copy-status]");
  const urlInput = document.querySelector("[data-copy-url]");

  if (headerShare) {
    headerShare.addEventListener("click", async () => {
      headerShare.disabled = true;
      if (typeof navigator.share === "function") {
        try {
          await navigator.share(shareData);
          headerShare.disabled = false;
          return;
        } catch (err) {
          if (err && err.name === "AbortError") {
            headerShare.disabled = false;
            return;
          }
        }
      }
      try {
        await copyTextToClipboard(shareUrl);
        if (statusEl) statusEl.textContent = "この記事のリンクをコピーしました";
        headerShare.classList.add("article__header-share--copied");
      } catch {
        if (statusEl) statusEl.textContent = "URLを選択しました。手動でコピーしてください";
        if (urlInput) {
          urlInput.hidden = false;
          urlInput.focus();
          urlInput.select();
        }
      }
      setTimeout(() => {
        headerShare.disabled = false;
        headerShare.classList.remove("article__header-share--copied");
      }, 1800);
    });
  }

  const copyBtn = document.querySelector("[data-copy-article-url]");
  if (copyBtn) {
    const copyIcon = copyBtn.querySelector("[data-copy-icon]");
    const checkIcon = copyBtn.querySelector("[data-check-icon]");

    copyBtn.addEventListener("click", async () => {
      copyBtn.disabled = true;
      if (urlInput) urlInput.value = shareUrl;
      try {
        await copyTextToClipboard(shareUrl);
        copyBtn.classList.add("article__share-btn--copied");
        copyBtn.setAttribute("aria-label", "コピーしました");
        if (copyIcon) copyIcon.hidden = true;
        if (checkIcon) checkIcon.hidden = false;
        if (statusEl) statusEl.textContent = "この記事のリンクをコピーしました";
        if (urlInput) urlInput.hidden = true;
      } catch {
        if (statusEl) statusEl.textContent = "URLを選択しました。手動でコピーしてください";
        if (urlInput) {
          urlInput.hidden = false;
          urlInput.focus();
          urlInput.select();
        }
      }
      setTimeout(() => {
        copyBtn.disabled = false;
        copyBtn.classList.remove("article__share-btn--copied");
        copyBtn.setAttribute("aria-label", "リンクをコピー");
        if (copyIcon) copyIcon.hidden = false;
        if (checkIcon) checkIcon.hidden = true;
        if (statusEl && urlInput && urlInput.hidden) statusEl.textContent = "";
      }, 2400);
    });
  }
</script>
