---
import type { Profile } from "../lib/microcms";
import { getTikTokUrl } from "../lib/microcms";
import { withBase } from "../config";

interface Props {
  profile: Profile;
  year: number;
}

const { profile, year } = Astro.props;
const tiktokUrl = getTikTokUrl(profile);
---

<footer class="footer">
  <div class="container footer__inner">
    {
      tiktokUrl && (
        <div class="footer__tiktok">
          <a
            href={tiktokUrl}
            class="tiktok-link tiktok-link--footer"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTokで見る（新しいタブで開きます）"
          >
            <svg
              class="tiktok-link__icon"
              viewBox="0 0 24 24"
              width="28"
              height="28"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"
              ></path>
            </svg>
          </a>
        </div>
      )
    }
    <span class="footer__mark">@08nsuiren</span>
    <nav class="footer__nav" aria-label="フッターナビゲーション">
      <a href={withBase("/privacy/")} class="footer__link">Privacy Policy</a>
    </nav>
    <p class="footer__copy">&copy; {year} Suiren Notes</p>
  </div>
</footer>
