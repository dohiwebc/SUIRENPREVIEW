---
import { IS_WORKS_PREVIEW } from "../config";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { href: "/", label: "Home", match: (p: string) => p === "/" },
  { href: "/works/", label: "Works", match: (p: string) => p.startsWith("/works") },
  { href: "/about/", label: "About", match: (p: string) => p.startsWith("/about") },
  { href: "/blog/", label: "Blog", match: (p: string) => p.startsWith("/blog") || p.startsWith("/articles") },
];

function isActive(match: (p: string) => boolean): boolean {
  return match(currentPath);
}
---

<header class="header">
  {
    IS_WORKS_PREVIEW && (
      <div class="preview-banner" role="status">
        Works Preview — 本番サイトとは別のプレビュー用サイトです
      </div>
    )
  }
  <div class="container header__inner">
    <a href="/" class="header__logo">
      <span class="header__logo-main">Suiren Notes</span>
      <span class="header__logo-sub">by 08nsuiren</span>
    </a>
    <nav class="nav" aria-label="メインナビゲーション">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={["nav__link", { "nav__link--active": isActive(item.match) }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
